{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "noImplicitAny": false,
    "rootDir": "./src",
    "strictNullChecks": true,
    "sourceMap": true,
    "outDir": "./dist",
    "resolveJsonModule": false,
    "types": ["node"],
  },
  "exclude": ["node_modules", "dist"],
}