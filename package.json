{
  "name": "crypto-broker-cli",
  "bin": {
    "cryptobroker-cli": "./dist/cli.js"
  },
  "version": "0.1.0",
  "main": "./dist/cli.js",
  "type": "module",
  "files": [
    "./dist"
  ],
  "scripts": {
    "build": "tsc --declaration",
    "clean": "tsc --build --clean --declaration",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "format": "eslint --fix && prettier --write 'src/**/*.{ts,tsx,js,json,md}'",
    "prepare": "husky || true"
  },
  "keywords": [
    "cryptobroker",
    "crypto-broker",
    "crypto-broker-cli",
    "apeiro",
    "apeirora",
    "crypto",
    "agility"
  ],
  "contributors": [
    "Arturo Guridi",
    "Miyana Stange"
  ],
  "license": "Apache-2.0",
  "description": "Client Javascript repository to interact with a deployed Crypto Broker Server",
  "dependencies": {
    "@open-crypto-broker/cryptobroker-client": "^0.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.213.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/instrumentation-winston": "^0.57.0",
    "@opentelemetry/sdk-trace-node": "^2.5.0",
    "@opentelemetry/winston-transport": "^0.23.0",
    "argparse": "^2.0.1",
    "long": "^5.3.2",
    "uuid": "^11.1.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "depcheck": "^1.4.7",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3"
  }
}
