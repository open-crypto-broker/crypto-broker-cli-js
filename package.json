{
  "name": "crypto-broker-cli",
  "bin": {
    "cryptobroker-cli": "./dist/cli.js"
  },
  "version": "0.2.3",
  "main": "./dist/cli.js",
  "type": "module",
  "files": [
    "./dist"
  ],
  "scripts": {
    "build": "tsc --declaration",
    "esbuild": "esbuild dist/cli.js --bundle --platform=node --outfile=bin/$APP_NAME --format=cjs --define:__VERSION__=\\\"${npm_package_version}\\\" --define:__GIT_COMMIT__=\\\"$(git rev-parse HEAD)\\\"",
    "clean": "tsc --build --clean",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "format": "eslint --fix && prettier --write 'src/**/*.{ts,tsx,js,json,md}'",
    "prepare": "husky || true"
  },
  "keywords": [
    "cryptobroker",
    "crypto-broker",
    "crypto-broker-cli",
    "apeiro",
    "apeirora",
    "crypto",
    "agility"
  ],
  "contributors": [
    "Arturo Guridi",
    "Miyana Stange"
  ],
  "engines": {
    "node": ">=24"
  },
  "license": "Apache-2.0",
  "description": "Client Javascript repository to interact with a deployed Crypto Broker Server",
  "dependencies": {
    "@open-crypto-broker/cryptobroker-client": "^0.2.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.215.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.215.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.215.0",
    "@opentelemetry/instrumentation-winston": "^0.59.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/winston-transport": "^0.25.0",
    "argparse": "^2.0.1",
    "long": "^5.3.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.0",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
